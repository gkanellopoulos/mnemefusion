  "key_innovations": [
    {
      "name": "Entity-First Retrieval Architecture",
      "problem": "Standard top-K semantic search misses scattered evidence across many turns",
      "solution": "Fetch ALL entity mentions from graph, then rank by relevance",
      "impact": "Solves multi-turn aggregation problem for entity queries"
    },
    {
      "name": "Content-Based Temporal Matching",
      "problem": "Temporal queries used recency instead of matching temporal context",
      "solution": "Match temporal expressions in query to temporal expressions in memory content",
      "impact": "Finds memories by temporal context, not just recency"
    },
    {
      "name": "Pre-Fusion Quality Control",
      "problem": "Low-quality semantic matches created noise (85% false positives)",
      "solution": "Two-stage filtering (pre-fusion 0.3 + post-fusion cross-dimensional validation)",
      "impact": "Reduced false positives to estimated 72-75%"
    }
